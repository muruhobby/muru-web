# Copy to .env.local and fill in. The storefront needs NO Midtrans keys —
# payment is handled by the Medusa backend's Midtrans provider (see muru-cms).

# Medusa backend origin.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Publishable API key: Medusa admin > Settings > Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Display currency.
NEXT_PUBLIC_DEFAULT_CURRENCY=idr
